    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst fecha = new Date().toLocaleDateString(\"es-AR\");\n\nlet lista = \"\";\n\nfor (const item of items) {\n  const mail = item.json;\n\n  lista += `\n  <div class=\"mail\">\n\n    <div class=\"meta\">\n      ID: <span class=\"id\">${mail.id}</span>\n    </div>\n\n    <div class=\"meta\">\n      Remitente: <span class=\"from\">${mail.from}</span>\n      ${mail.prioridad ? `<span class=\"tag prioridad-${mail.prioridad}\">${mail.prioridad}</span>` : \"\"}\n    </div>\n\n    <div class=\"body\">\n      ${mail.body}\n    </div>\n\n  </div>\n  `;\n}\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n\n<style>\n\nbody{\n  font-family: Arial, Helvetica, sans-serif;\n  background:#f4f6f8;\n  padding:30px;\n}\n\n.container{\n  max-width:720px;\n  margin:auto;\n  background:white;\n  border-radius:10px;\n  padding:28px;\n  box-shadow:0 4px 14px rgba(0,0,0,0.08);\n}\n\n.header{\n  border-bottom:1px solid #eee;\n  padding-bottom:12px;\n  margin-bottom:25px;\n}\n\n.title{\n  font-size:22px;\n  font-weight:700;\n  color:#1f2937;\n}\n\n.date{\n  font-size:13px;\n  color:#6b7280;\n  margin-top:4px;\n}\n\n.mail{\n  border:1px solid #e5e7eb;\n  border-radius:8px;\n  padding:16px;\n  margin-bottom:16px;\n  background:#fafafa;\n}\n\n.meta{\n  font-size:13px;\n  color:#6b7280;\n}\n\n.id{\n  font-weight:600;\n  color:#374151;\n}\n\n.from{\n  font-weight:600;\n  color:#111827;\n}\n\n.body{\n  margin-top:10px;\n  font-size:14px;\n  line-height:1.5;\n  color:#374151;\n}\n\n.tag{\n  display:inline-block;\n  font-size:11px;\n  padding:3px 8px;\n  border-radius:4px;\n  margin-left:6px;\n}\n\n.prioridad-alta{\n  background:#fee2e2;\n  color:#b91c1c;\n}\n\n.footer{\n  margin-top:25px;\n  text-align:center;\n  font-size:12px;\n  color:#9ca3af;\n}\n\n</style>\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<div class=\"header\">\n  <div class=\"title\">📬 Correos que requieren revisión</div>\n  <div class=\"date\">${fecha}</div>\n</div>\n\n${lista}\n\n<div class=\"footer\">\nGenerado automáticamente por el sistema\n</div>\n\n</div>\n\n</body>\n</html>\n`;\n\nreturn [\n  {\n    json: {\n      html\n    }\n  }\n];"
      },
