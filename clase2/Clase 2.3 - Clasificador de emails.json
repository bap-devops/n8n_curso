      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  try {\n    const text = item.json.text.\n      replace(/```json\\s*|\\s*```/g, \"\").trim();\n    const res = JSON.parse(text);\n    return { json: res };\n  } catch (error) {\n    throw new Error('El modelo no devolvió JSON válido');\n  }\n});"
